CW EQU P1.0
STOP EQU P1.1
CCW  EQU P1.2
INCR EQU P1.3
DECR EQU P1.4
	
ORG 0H
AJMP MAIN
ORG 30H
	MAIN: 
	SETB CW
	SETB STOP
	SETB CCW
	SETB P2.2
	MOV R1,10
	MOV R2,90
	CHECK:
	JNB CW, TURN_RIGHT
	JNB STOP, OFF
	JNB CCW, TURN_LEFT
	SJMP CHECK
	
	TURN_RIGHT:
	CLR P2.1
	SETB P2.0
	SJMP CHECK
	TURN_LEFT:
	SETB P2.1
	CLR P2.0
	SJMP CHECK
	OFF:
	CLR P2.0
	CLR P2.1
	SJMP CHECK
	
	DELAY_ON:
	MOV A,R1
	MOV R4,255
	H2:MOV R6,50
	H1:MOV R3,A
	HERE1: DJNZ R3,HERE1
	DJNZ R6,H1
	DJNZ R4,H2
	CLR P2.0
	CLR P2.1
	MOV A,R2
	MOV R4,255
	A2:MOV R6,50
	A1:MOV R3,A
	HERE: DJNZ R3,HERE
	DJNZ R6,A1
	DJNZ R4,A2
	SJMP TURN_RIGHT
	
	
	END
